# Supabase — copy from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# HQ super-admin credentials (server-only, never expose to client)
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=your-strong-password-here

# Comma-separated internal staff emails that bypass the demo trial expiry check
# These users must exist in Supabase Auth
INTERNAL_STAFF_EMAILS=you@yourdomain.com,colleague@yourdomain.com

# Resend — email delivery (get your key at resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
